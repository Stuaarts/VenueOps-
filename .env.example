# VenueOps local development defaults
# Copy to .env only if you want to customize docker compose values.

POSTGRES_DB=venueops
POSTGRES_USER=venueops
POSTGRES_PASSWORD=venueops_dev_password

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=venueops;Username=venueops;Password=venueops_dev_password
# Hosted deployments can alternatively set DATABASE_URL to a provider URL such as:
# postgresql://user:password@host:5432/database?sslmode=require
DATABASE_URL=
Jwt__Issuer=VenueOps
Jwt__Audience=VenueOpsClient
Jwt__SigningKey=replace-with-a-long-random-secret-in-real-deployments
SeedDemoData=true

VITE_API_BASE_URL=http://localhost:5000/api
VITE_USE_MOCKS=false
